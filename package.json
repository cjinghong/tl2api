    "login": "node src/login.js",
    "mcp": "node src/mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^4.4.3"
  }
}
